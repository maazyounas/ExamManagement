# Local MongoDB (recommended). Start with: docker compose up -d mongo
MONGO_URI=mongodb://127.0.0.1:27017/examdb

# Or MongoDB Atlas (mongodb+srv://...)
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/examdb

# Set to false to disable in-memory DB fallback when local/Atlas fail
# USE_MEMORY_DB=true

JWT_SECRET=change_this_to_a_long_random_string
PORT=5000
